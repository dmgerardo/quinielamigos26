{
  "rules": {
    "publicTournaments": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && root.child('tournaments').child($code).child('admin').val() === auth.uid",
        "name":      { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40" },
        "adminName": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20" },
        "createdAt": { ".validate": true },
        "$other":    { ".validate": false }
      }
    },

    "tournaments": {
      "$code": {
        ".read": "auth != null",

        ".write": "auth != null && !data.exists() && newData.child('admin').val() === auth.uid",

        "name": {
          ".write": "auth != null && root.child('tournaments').child($code).child('admin').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40"
        },

        "createdAt": { ".validate": true },

        "admin": {
          ".validate": "newData.val() === auth.uid"
        },

        "participants": {
          "$pid": {
            ".write": "auth != null",
            "name":         { ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 20" },
            "championPick": { ".validate": "newData.isString() && (!data.exists() || data.val() === '' || data.val() === newData.val())" },
            "joinedAt":     { ".validate": true },
            "passwordHash": { ".validate": "newData.isString() && newData.val().length === 64 && (!data.exists() || data.val() === newData.val())" },
            "$other": { ".validate": false }
          }
        },

        "matches": {
          ".write": "auth != null && root.child('tournaments').child($code).child('admin').val() === auth.uid",
          "$matchId": {
            "realA":  { ".validate": "newData.val() === null || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 30)" },
            "realB":  { ".validate": "newData.val() === null || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 30)" },
            "played": { ".validate": "newData.isBoolean()" }
          }
        },

        "predictions": {
          "$matchId": {
            "$pid": {
              ".write": "auth != null && root.child('tournaments').child($code).child('matches').child($matchId).child('played').val() !== true && (!root.child('tournaments').child($code).child('matches').child($matchId).child('kickoffMs').exists() || now < root.child('tournaments').child($code).child('matches').child($matchId).child('kickoffMs').val() - 3600000)",
              "a":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20" },
              "b":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20" },
              "at": { ".validate": true },
              "$other": { ".validate": false }
            }
          }
        }
      }
    }
  }
}
